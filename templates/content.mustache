{{!
    @template block_plugindirectory/content

    Compact layout: only "new" plugins shown by default, all others hidden
    behind a toggle button.

    Context:
    * plugincount, has_new, newcount
    * newplugins / plugins (arrays)
    * typeoptions: [{value, label}]

    Example context (json):
    {
        "plugincount": "27 additional plugins installed",
        "has_new": true,
        "newcount": 1,
        "newplugins": [],
        "plugins": [],
        "typeoptions": []
    }
}}
<div class="block-plugindirectory" data-region="plugindir">

    {{! ── NEW PLUGINS SECTION ── }}
    {{#has_new}}
    <div class="plugindir-new-section mb-2" data-region="plugindir-new-section">
        <div class="plugindir-new-header d-flex align-items-center mb-1">
            <span class="plugindir-new-pulse mr-2"></span>
            <span class="text-success small font-weight-bold">{{#str}} new_section, block_plugindirectory {{/str}}</span>
            <span class="badge badge-success ml-auto">{{newcount}}</span>
        </div>
        {{#newplugins}}
        {{> block_plugindirectory/row }}
        {{/newplugins}}
    </div>
    {{/has_new}}

    {{! ── TOGGLE BUTTON ── }}
    <button type="button"
            class="btn btn-sm btn-link p-0 plugindir-toggle-all"
            data-action="plugindir-show-all">
        <span data-region="toggle-text">▸ {{plugincount}}</span>
    </button>

    {{! ── COLLAPSIBLE: search + full list ── }}
    <div data-region="plugindir-allwrap" hidden>
        <div class="d-flex mt-2 mb-2" style="gap:0.4rem;">
            <input type="search"
                   class="form-control form-control-sm flex-grow-1"
                   data-action="plugindir-search"
                   placeholder="🔍 Suchen…"
                   aria-label="Plugins durchsuchen">
            <select class="form-control form-control-sm w-auto"
                    data-action="plugindir-typefilter"
                    aria-label="Nach Plugintyp filtern">
                <option value="">{{#str}} filter_alltypes, block_plugindirectory {{/str}}</option>
                {{#typeoptions}}
                <option value="{{value}}">{{label}}</option>
                {{/typeoptions}}
            </select>
        </div>
        <div class="small text-muted mb-2" data-region="plugindir-empty" hidden>Keine Treffer.</div>

        <div data-region="plugindir-list">
        {{#plugins}}
        {{> block_plugindirectory/row }}
        {{/plugins}}
        </div>
    </div>

</div>

<script>
(function() {
    var roots = document.querySelectorAll('[data-region="plugindir"]');
    var root  = roots[roots.length - 1];
    if (!root || root.dataset.plugindirInit) { return; }
    root.dataset.plugindirInit = '1';

    var input    = root.querySelector('[data-action="plugindir-search"]');
    var typesel  = root.querySelector('[data-action="plugindir-typefilter"]');
    var toggle   = root.querySelector('[data-action="plugindir-show-all"]');
    var togText  = root.querySelector('[data-region="toggle-text"]');
    var allwrap  = root.querySelector('[data-region="plugindir-allwrap"]');
    var rows     = root.querySelectorAll('[data-region="plugindir-list"] [data-plugindir-row]');
    var emptyMsg = root.querySelector('[data-region="plugindir-empty"]');
    var collapsedLabel = togText ? togText.textContent : '';
    var expandedLabel  = '▾ Einklappen';

    function applyFilter() {
        if (!allwrap || allwrap.hidden) { return; }
        var q  = (input ? input.value : '').trim().toLowerCase();
        var tf = typesel ? typesel.value : '';
        var visible = 0;
        rows.forEach(function(row) {
            var hay = (row.dataset.search || '').toLowerCase();
            var qMatch = q === '' || hay.indexOf(q) !== -1;
            var tMatch = tf === '' || row.dataset.type === tf;
            var match = qMatch && tMatch;
            row.hidden = !match;
            if (match) { visible++; }
        });
        if (emptyMsg) { emptyMsg.hidden = visible !== 0; }
    }

    function toggleAll() {
        if (!allwrap) { return; }
        allwrap.hidden = !allwrap.hidden;
        if (togText) {
            togText.textContent = allwrap.hidden ? collapsedLabel : expandedLabel;
        }
        if (!allwrap.hidden && input) { input.focus(); }
    }

    if (input)   { input.addEventListener('input', applyFilter); }
    if (typesel) { typesel.addEventListener('change', applyFilter); }
    if (toggle)  { toggle.addEventListener('click', toggleAll); }

    // Prevent action links inside summary from toggling details.
    root.querySelectorAll('summary a').forEach(function(a) {
        a.addEventListener('click', function(ev) { ev.stopPropagation(); });
    });
})();
</script>
